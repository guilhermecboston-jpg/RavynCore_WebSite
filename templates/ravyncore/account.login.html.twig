<p>Access your account panel or create a new one to begin your journey.</p>

<form action="{{ getLink('account/manage') }}" method="post">
	{% if redirect is not null %}
		<input type="hidden" name="redirect" value="{{ redirect }}" />
	{% endif %}

	<div class="TableContainer">
		<table class="Table1" cellpadding="0" cellspacing="0">
			<tr>
				<td>
					<div class="InnerTableContainer">
						<table style="width:100%;">
							<tr>
								<td class="LabelV"><span{% if error is not null %} class="red"{% endif %}>{{ account_login_by }}:</span></td>
								<td style="width:100%;"><input type="text" name="account_login" maxlength="30" autofocus /></td>
							</tr>
							<tr>
								<td class="LabelV"><span{% if error is not null %} class="red"{% endif %}>Password:</span></td>
								<td><input type="password" name="password_login" maxlength="29" /></td>
							</tr>
							<tr>
								<td class="LabelV"></td>
								<td>
									<input type="checkbox" id="remember_me" name="remember_me" value="true" />
									<label for="remember_me">Remember me</label>
								</td>
							</tr>
							{% if error is not null %}
								<tr><td></td><td><span class="FormFieldError">{{ error }}</span></td></tr>
							{% endif %}
						</table>
					</div>
				</td>
			</tr>
		</table>
	</div>

	<br />
	<div style="display:flex; gap:10px; justify-content:center; flex-wrap:wrap;">
		<button type="submit" class="rc-btn rc-btn-highlight">Login</button>
		<a class="rc-btn" href="{{ getLink('account/lost') }}">Forgot Password</a>
	</div>
</form>
