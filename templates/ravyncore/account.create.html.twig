{{ hook('HOOK_ACCOUNT_CREATE_BEFORE_FORM') }}
<form action="{{ getLink('account/create') }}" method="post" id="createaccount">
	<div class="TableContainer">
		<table class="Table5" cellpadding="0" cellspacing="0">
			<tr>
				<td>
					<div class="InnerTableContainer">
						<table style="width:100%;">
							{{ hook('HOOK_ACCOUNT_CREATE_BEFORE_BOXES') }}
							<tr>
								<td>
									<div class="TableContentContainer">
										<table class="TableContent" width="100%">
											<tbody>
											<tr class="LabelH"><td colspan="2">Create {{ config.lua.serverName }} Account</td></tr>

											{{ hook('HOOK_ACCOUNT_CREATE_BEFORE_ACCOUNT') }}
											{% if config.account_login_by_email %}
											<tr>
												<td class="LabelV" style="width: 170px;"><span{% if errors.account is defined %} class="red"{% endif %}>Account {% if constant('USE_ACCOUNT_NAME') %}Name{% else %}Number{% endif %}:</span></td>
												<td><input type="text" name="account" id="account_input" maxlength="{% if constant('USE_ACCOUNT_NAME') %}30{% else %}10{% endif %}" /></td>
											</tr>
											<tr><td></td><td><span id="account_error" class="FormFieldError">{% if errors.account is defined %}{{ errors.account }}{% endif %}</span></td></tr>
											{% endif %}
											{{ hook('HOOK_ACCOUNT_CREATE_AFTER_ACCOUNT') }}

											<tr>
												<td class="LabelV"><span{% if errors.email is defined %} class="red"{% endif %}>Email:</span></td>
												<td><input type="text" name="email" id="email" maxlength="50" value="{{ email }}" /></td>
											</tr>
											<tr><td></td><td><span id="email_error" class="FormFieldError">{% if errors.email is defined %}{{ errors.email }}{% endif %}</span></td></tr>

											{% if config.account_country %}
											<tr>
												<td class="LabelV"><span{% if errors.country[0] is defined %} class="red"{% endif %}>Country:</span></td>
												<td>
													<select name="country" id="account_country">
														{% for code, country_ in countries %}
															<option value="{{ code }}"{% if(country is defined and country == code) or (country is null and country_recognized == code) %} selected{% endif %}>{{ country_ }}</option>
														{% endfor %}
													</select>
												</td>
											</tr>
											{% if errors.country is defined %}<tr><td></td><td><span class="FormFieldError">{{ errors.country }}</span></td></tr>{% endif %}
											{% endif %}

											<tr>
												<td class="LabelV"><span{% if errors.password is defined %} class="red"{% endif %}>Password:</span></td>
												<td><input type="password" name="password" id="password" maxlength="29" /></td>
											</tr>
											<tr><td></td><td><span id="password_error" class="FormFieldError">{% if errors.password is defined %}{{ errors.password }}{% endif %}</span></td></tr>
											<tr>
												<td class="LabelV"><span{% if errors.password is defined %} class="red"{% endif %}>Repeat Password:</span></td>
												<td><input type="password" name="password2" id="password2" maxlength="29" /></td>
											</tr>
											<tr><td></td><td><span id="password2_error" class="FormFieldError">{% if errors.password is defined %}{{ errors.password }}{% endif %}</span></td></tr>
											</tbody>
										</table>
									</div>
								</td>
							</tr>

							{% if (not config.mail_enabled or not config.account_mail_verify) and config.account_create_character_create %}
							<tr><td><br /></td></tr>
							<tr>
								<td>
									<div class="TableContentContainer">
										<table class="TableContent" width="100%">
											<tbody>
											<tr class="LabelH"><td colspan="2">First Character</td></tr>
											<tr>
												<td class="LabelV" style="width: 170px;"><span{% if errors.name is defined %} class="red"{% endif %}>Character Name:</span></td>
												<td><input id="character_name" name="name" maxlength="{{ config.character_name_max_length }}" value="{{ name }}" onkeyup="checkName();" /></td>
											</tr>
											<tr><td></td><td><span id="character_error" class="FormFieldError">{% if errors.name is defined %}{{ errors.name }}{% endif %}</span></td></tr>
											<tr>
												<td class="LabelV"><span{% if errors.sex is defined %} class="red"{% endif %}>Sex:</span></td>
												<td>
													{% set i = 0 %}
													{% for id, gender in config.genders|reverse(true) %}
														{% set i = i + 1 %}
														<span class="OptionContainer" style="margin-right: 14px;">
															<input type="radio" name="sex" id="sex{{ i }}" value="{{ id }}"{% if sex is not null and sex == id %} checked="checked"{% endif %}>
															<label for="sex{{ i }}">{{ gender|lower }}</label>
														</span>
													{% endfor %}
												</td>
											</tr>
											<tr><td></td><td><span id="sex_error" class="FormFieldError">{% if errors.sex is defined %}{{ errors.sex }}{% endif %}</span></td></tr>
											</tbody>
										</table>
									</div>
								</td>
							</tr>
							{% endif %}

							<tr><td><br /></td></tr>
							<tr>
								<td>
									<div class="TableContentContainer">
										<table class="TableContent" width="100%">
											<tbody>
											<tr>
												<td>
													<input type="checkbox" id="accept_rules" name="accept_rules" value="true"{% if accept_rules %} checked{% endif %}/>
													<label for="accept_rules">I agree with <a href="?subtopic=rules" target="_blank">{{ config.lua.serverName }} Rules</a>.</label>
													{% if errors.accept_rules is defined %}<div class="FormFieldError">{{ errors.accept_rules }}</div>{% endif %}
												</td>
											</tr>
											</tbody>
										</table>
									</div>
								</td>
							</tr>
							{{ hook('HOOK_ACCOUNT_CREATE_AFTER_BOXES') }}
						</table>
					</div>
				</td>
			</tr>
		</table>
	</div>

	<br />
	<div style="text-align:center;">
		<input type="hidden" name="save" value="1">
		<button type="submit" class="rc-btn rc-btn-highlight">Create Account</button>
	</div>
</form>
{{ hook('HOOK_ACCOUNT_CREATE_AFTER_FORM') }}
<script type="text/javascript" src="tools/check_name.js"></script>
