<form action="{{ link }}" method="post">
	<div class="TableContainer">
		<table class="Table1" cellpadding="0" cellspacing="0">
			<tbody>
			<tr>
				<td>
					<div class="InnerTableContainer">
						<table style="width:100%;">
							<tbody>
							<tr class="LabelH"><td colspan="3">Search Character</td></tr>
							<tr>
								<td style="vertical-align:middle;" class="LabelV150">Character Name:</td>
								<td class="GreedyCell">
									<input style="width: 100%;" name="name" value="" maxlength="29"{% if autofocus %} autofocus{% endif %}>
								</td>
								<td>
									<div style="margin-left: 10px;">
										<button type="submit" class="rc-btn">Search</button>
									</div>
								</td>
							</tr>
							</tbody>
						</table>
					</div>
				</td>
			</tr>
			</tbody>
		</table>
	</div>
</form>
