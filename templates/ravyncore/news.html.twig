<div class="TableContainer">
	<table class="Table3" cellpadding="0" cellspacing="0" style="width:100%;">
		<tbody>
		<tr>
			<td>
				<div class="InnerTableContainer">
					<div class="TableContentContainer">
						<table class="TableContent" width="100%">
							<tbody>
							<tr class="LabelH">
								<td>
									<strong>{{ title }}</strong>
									<span style="float:right;"><small>{{ date|date(config.news_date_format) }}</small></span>
								</td>
							</tr>
							<tr class="Odd">
								<td>{{ content|raw }}</td>
							</tr>
							{% if comments is not null %}
								<tr class="Even">
									<td style="text-align: right;"><a href="{{ comments }}">Comment on this news</a></td>
								</tr>
							{% endif %}
							</tbody>
						</table>
					</div>
				</div>
			</td>
		</tr>
		</tbody>
	</table>
</div>
<br />
